# ══════════════════════════════════════════════════════════════
#  MIRACLE INTEL v5.3 - 미라클탐정사무소 환경 설정
# ══════════════════════════════════════════════════════════════
#
#  AI_PROVIDER 설정: 사용할 AI를 선택하세요
#    gemini     - Google Gemini 2.5 Flash (추천·완전무료)
#    groq       - Groq Llama 3.3 70B (완전무료·초고속)
#    anthropic  - Anthropic Claude (유료)
#    auto       - 설정된 키 자동 선택
#
AI_PROVIDER=gemini

# ──────────────────────────────────────────────────────────────
#  [1] Google Gemini API 키 (완전 무료·신용카드 불필요)
#  발급: https://aistudio.google.com
#        → 구글 계정 로그인 → "Get API Key" 클릭 → 키 복사
# ──────────────────────────────────────────────────────────────
GEMINI_API_KEY=YOUR_GEMINI_KEY_HERE

# ──────────────────────────────────────────────────────────────
#  [2] Groq API 키 (완전 무료·신용카드 불필요·초고속)
#  발급: https://console.groq.com
#        → 회원가입 → API Keys → Create API Key
# ──────────────────────────────────────────────────────────────
GROQ_API_KEY=YOUR_GROQ_KEY_HERE

# ──────────────────────────────────────────────────────────────
#  [3] Anthropic API 키 (선택사항·유료)
#  발급: https://console.anthropic.com
# ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# 서버 설정
HOST=0.0.0.0
PORT=8000
